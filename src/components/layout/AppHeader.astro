---
interface Props {
  active?: 'inicio' | 'muro' | 'perfil'
}
const { active } = Astro.props
const link = (id: string) =>
  active === id ? 'text-brand-chalk' : 'text-brand-chalk/80 transition-colors hover:text-brand-chalk'
---

<header class="sticky top-0 z-40 border-b border-white/10 bg-brand-primary">
  <div class="mx-auto flex max-w-5xl items-center justify-between px-6 py-4">
    <a href="/app" class="font-display text-xl font-[800] tracking-tight text-brand-chalk">
      Capitana BSAS
    </a>
    <nav class="flex items-center gap-6 font-display text-sm font-[600]">
      <a href="/app" class={link('inicio')}>Inicio</a>
      <a href="/muro" class={link('muro')}>Muro</a>
      <a href="/app/perfil" class={link('perfil')}>Mi presentación</a>
      <button id="salir" class="text-brand-accent-light transition-colors hover:text-brand-chalk">
        Salir
      </button>
    </nav>
  </div>
</header>

<script>
  document.getElementById('salir')?.addEventListener('click', async () => {
    await fetch('/api/auth/sign-out', { method: 'POST' })
    window.location.href = '/ingresar'
  })
</script>
