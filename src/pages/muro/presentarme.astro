---
import AppHeader from '../../components/layout/AppHeader.astro'
import BaseLayout from '../../layouts/BaseLayout.astro'
import { createDb } from '../../lib/db'
import { getPublicProfile } from '../../lib/db/queries'
import { getServerEnv } from '../../lib/env'

export const prerender = false

const user = Astro.locals.user
if (!user) return Astro.redirect('/ingresar')

const targetId = Astro.url.searchParams.get('a')
if (!targetId || targetId === user.id) return Astro.redirect('/muro')

const env = getServerEnv()
const db = createDb(env.DATABASE_URL)
const target = await getPublicProfile(db, targetId)
if (!target) return Astro.redirect('/muro')

const error = Astro.url.searchParams.get('error')
const primerNombre = target.name.split(' ')[0]
---

<BaseLayout title={`Presentarte a ${primerNombre}`}>
  <AppHeader active="muro" />

  <section class="bg-brand-chalk px-6 py-10">
    <div class="mx-auto max-w-xl">
      <a href="/muro" class="font-display text-sm font-[600] text-brand-accent-ink hover:underline">
        ← Volver al muro
      </a>

      <h1 class="mt-4 font-display text-3xl font-[800] text-brand-primary">
        Presentarte a {target.name}
      </h1>
      <p class="mt-2 font-body text-text-secondary">
        Le va a llegar tu mensaje por correo, junto con tu nombre y tu email para que pueda
        responderte. No compartimos su correo con vos.
      </p>

      {
        target.busco && (
          <div class="mt-5 rounded-[10px] bg-brand-accent/10 p-4">
            <p class="font-display text-[11px] font-[700] uppercase tracking-[0.14em] text-brand-accent-ink">
              {primerNombre} busca
            </p>
            <p class="mt-1 font-body text-sm text-text-primary">{target.busco}</p>
          </div>
        )
      }

      {
        error && (
          <div
            class="mt-5 rounded-[10px] border border-brand-secondary/40 bg-brand-secondary/10 px-4 py-3 font-body text-sm text-brand-secondary-ink"
            role="status"
          >
            No pudimos enviar tu mensaje. Probá de nuevo en un momento.
          </div>
        )
      }

      <form method="POST" action="/api/presentarme" class="mt-6 space-y-4">
        <input type="hidden" name="a" value={targetId} />
        <div>
          <label for="mensaje" class="mb-1.5 block font-display text-sm font-[600] text-brand-primary">
            Tu mensaje
          </label>
          <textarea
            id="mensaje"
            name="mensaje"
            required
            minlength="10"
            maxlength="1000"
            rows="5"
            placeholder={`Hola ${primerNombre}, me presento: soy... y me encantaría conectar porque...`}
            class="w-full rounded-[10px] border border-border bg-surface px-4 py-3 font-body text-text-primary outline-none transition-colors focus:border-brand-accent focus:ring-2 focus:ring-brand-accent/30"
          ></textarea>
        </div>
        <button
          type="submit"
          class="w-full rounded-full bg-brand-secondary px-6 py-3 font-display text-base font-[700] text-white transition-colors hover:bg-brand-secondary-ink sm:w-auto"
        >
          Enviar presentación →
        </button>
      </form>
    </div>
  </section>
</BaseLayout>
