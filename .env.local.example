# ─── Base de datos (Neon / Postgres) ───────────────────────────────
# Connection string de Neon. Solo servidor. En prod: wrangler secret put DATABASE_URL
DATABASE_URL=postgres://user:pass@host/db?sslmode=require

# ─── Better Auth ───────────────────────────────────────────────────
# Secreto para firmar sesiones. Generar con: openssl rand -base64 32
# En prod: wrangler secret put BETTER_AUTH_SECRET
BETTER_AUTH_SECRET=
# URL base de la app (para callbacks / magic links)
BETTER_AUTH_URL=http://localhost:4321

# ─── Email (Resend) ────────────────────────────────────────────────
# Solo servidor. En prod: wrangler secret put RESEND_API_KEY
RESEND_API_KEY=
RESEND_FROM_EMAIL=hola@jessicaestalella.com

# ─── URLs públicas (van al cliente, prefijo PUBLIC_) ───────────────
# Dev: http://localhost:4321 · Prod: https://capitanabsas.jessicaestalella.com
PUBLIC_SITE_URL=http://localhost:4321
