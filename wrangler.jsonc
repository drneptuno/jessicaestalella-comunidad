{
	"compatibility_date": "2026-06-02",
	"compatibility_flags": ["nodejs_compat"],
	"name": "jessicaestalella-comunidad",
	"main": "@astrojs/cloudflare/entrypoints/server",
	"assets": {
		"directory": "./dist",
		"binding": "ASSETS"
	},
	"observability": {
		"enabled": true
	}
	// Secretos (DATABASE_URL, BETTER_AUTH_SECRET, RESEND_API_KEY) NUNCA acá.
	// En prod: wrangler secret put <NOMBRE>
}
